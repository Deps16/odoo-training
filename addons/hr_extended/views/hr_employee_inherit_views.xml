<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- hr.employee form view -->
    <record id="hr_employee_inherit_view_form" model="ir.ui.view">
        <field name="name">hr.employee.view.inherit.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='emergency_contact']" position="after">
                <field name="berak_count"/>
            </xpath>
        </field>
    </record>
</odoo>