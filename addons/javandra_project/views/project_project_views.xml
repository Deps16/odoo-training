<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="edit_project_inherited" model="ir.ui.view">
        <field name="name">project.project.form.inherited</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Javandra Project Details" name="page_javandra_details">
                    <group>
                        <group name="po_info" string="PO &amp; Type Information">
                            <field name="x_po_number"/>
                            <field name="x_po_amount"/>
                            <field name="x_project_type"/>
                        </group>
                        <group name="actors_info" string="Management &amp; Relational">
                            <field name="x_project_director_id" options="{'no_create': True}"/>
                            <field name="x_subcontractor_id" options="{'no_create': True}"/>
                            <field name="x_laravel_id" readonly="1" groups="base.group_no_one"/>
                        </group>
                    </group>
                </page>
                <page string="Budgets" name="page_project_budgets">
                    <field name="x_budget_ids" context="{'default_project_id': active_id}">
                        <tree string="Budgets" editable="bottom">
                            <field name="date"/>
                            <field name="type"/>
                            <field name="amount"/>
                            <field name="description"/>
                            <field name="user_id" readonly="1"/>
                        </tree>
                        <form string="Budget Detail">
                            <group>
                                <group>
                                    <field name="date"/>
                                    <field name="type"/>
                                    <field name="amount"/>
                                </group>
                                <group>
                                    <field name="user_id" readonly="1"/>
                                    <field name="description"/>
                                </group>
                            </group>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_project_inherited" model="ir.ui.view">
        <field name="name">project.project.tree.inherited</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="x_po_number" optional="show"/>
                <field name="x_project_director_id" optional="show"/>
                <field name="x_subcontractor_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>