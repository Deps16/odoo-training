<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form2_inherited" model="ir.ui.view">
        <field name="name">project.task.form.inherited</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Site Details" name="page_site_details">
                    <group>
                        <group name="site_personnel" string="Personnel In Charge">
                            <field name="x_supervisor_id" options="{'no_create': True}"/>
                            <field name="x_subcontractor_id" options="{'no_create': True}"/>
                        </group>
                        <group name="site_milestones" string="Key Dates">
                            <field name="x_done_date"/>
                            <field name="x_service_date"/>
                            <field name="x_bast_date"/>
                            <field name="x_laravel_id" readonly="1" groups="base.group_no_one"/>
                        </group>
                    </group>
                </page>
                
                <page string="Site Chronology" name="page_site_chronology">
                    <field name="x_chronology_ids" context="{'default_project_site_id': active_id}">
                        <tree string="Chronologies">
                            <field name="event_date"/>
                            <field name="title"/>
                            <field name="user_id"/>
                            <field name="x_laravel_id" column_invisible="True"/>
                        </tree>
                        <form string="Chronology Details">
                            <sheet>
                                <group>
                                    <group>
                                        <field name="title"/>
                                        <field name="event_date"/>
                                        <field name="user_id" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="image" widget="image" filename="image_name"/>
                                        <field name="image_name" invisible="1"/>
                                    </group>
                                </group>
                                <notebook>
                                    <page string="Description" name="page_desc">
                                        <field name="description" widget="html" placeholder="Describe the site progress, issues, or details here..."/>
                                    </page>
                                </notebook>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_task_tree2_inherited" model="ir.ui.view">
        <field name="name">project.task.tree.inherited</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="x_supervisor_id" optional="show"/>
                <field name="x_subcontractor_id" optional="show"/>
                <field name="x_bast_date" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>